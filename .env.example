# ============================================================================
# short-video-media: ルート .env.example
# ============================================================================
# このファイルはローカル開発用。本番値は Vercel / Railway / GitHub Actions の
# 各シークレットマネージャに設定すること。
# 1. このファイルを `.env` にコピー
# 2. 各値を本物の値に置き換え
# 3. `.env` は .gitignore に登録済み (絶対にコミットしない)

# ----------------------------------------------------------------------------
# 共通 (apps/api と apps/web で同一値)
# ----------------------------------------------------------------------------
# JWT HS256 署名鍵 / Auth.js セッション鍵 (32 文字以上)
# 生成: openssl rand -hex 32
AUTH_SECRET=

# provider sub のハッシュソルト (16 文字以上)
# 生成: openssl rand -hex 16
# ローテーション手順は docs/environments.md 参照
APP_USER_SALT=

# ----------------------------------------------------------------------------
# apps/api (FastAPI)
# ----------------------------------------------------------------------------
# 環境識別子 (production の場合に AUTH_SECRET / APP_USER_SALT の検証が厳格化)
APP_ENV=development

# 配置先識別子 (development / railway / xserver / aws / gcp / k8s)。
# scheduler.py の DATABASE_URL ホスト名チェック分岐に使われる。
DEPLOY_TARGET=development

# DB 接続 (asyncpg ドライバへ自動正規化される)
DATABASE_URL=postgresql://shortvideo:shortvideo@127.0.0.1:5432/shortvideo

# events API レート制限 (IP ベースの sliding window)
EVENTS_RATE_LIMIT_PER_SECOND=10
EVENTS_RATE_LIMIT_PER_MINUTE=120

# sign-in / feed / resolve-mp4 のレート制限。
# 全エンドポイント共通の SlidingWindowRateLimiter (apps/api/app/core/rate_limit.py)
# を使う。値はいずれも IP ベース sliding window の上限値。
# - sign-in : 大量ユーザー作成・盗まれた exchange JWT の総当たり対策で保守的
# - feed     : 通常スクロール (offset 移動) は妨げないよう緩め
# - resolve-mp4 : DMM への外部リクエストを伴うため events と同程度
SIGNIN_RATE_LIMIT_PER_SECOND=5
SIGNIN_RATE_LIMIT_PER_MINUTE=20
FEED_RATE_LIMIT_PER_SECOND=20
FEED_RATE_LIMIT_PER_MINUTE=240
RESOLVE_RATE_LIMIT_PER_SECOND=10
RESOLVE_RATE_LIMIT_PER_MINUTE=120

# (任意) Redis URL。未設定なら resolver MP4 短期キャッシュやレート制御の
# 共有はすべて in-process フォールバックになる。マルチインスタンス本番では
# 設定推奨。redis 依存は extras (`pip install -e "apps/api[cache]"`) のため、
# REDIS_URL を設定しても redis パッケージ未インストール環境では自動で no-op。
# 例: REDIS_URL=redis://localhost:6379/0
# REDIS_URL=

# (任意) Sentry DSN。設定すると apps/api / apps/web で例外を Sentry に送出する。
# 未設定なら一切送信しない (テストやローカル開発に影響しない)。
# SENTRY_DSN=

# CORS (カンマ区切り)
CORS_ALLOW_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# apps/web (Next.js)
# ----------------------------------------------------------------------------
# Twitter / Discord OAuth (developer portal から取得)
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# API 接続 URL (サーバー側 / クライアント側)
API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# GA4 (任意)
NEXT_PUBLIC_GA_ID=

# ----------------------------------------------------------------------------
# 広告 (ExoClick) - apps/web
# ----------------------------------------------------------------------------
# 全体スイッチ。true で配信。false / 未設定なら個別 ON でも一切表示しない。
NEXT_PUBLIC_ADS_ENABLED=false

# 各広告 zone の個別 ON/OFF。デフォルト OFF。全体スイッチと AND される。
NEXT_PUBLIC_AD_NATIVE_ENABLED=false
NEXT_PUBLIC_AD_MOBILE_BANNER_300X250_ENABLED=false
NEXT_PUBLIC_AD_MOBILE_BANNER_300X100_ENABLED=false
# Fullpage Interstitial は後で A/B テスト用。デフォルト OFF。
NEXT_PUBLIC_AD_FULLPAGE_INTERSTITIAL_ENABLED=false

# 各 zoneid (環境変数で上書き可能。デフォルトは ExoClick から払い出された値)。
NEXT_PUBLIC_EXOCLICK_NATIVE_ZONE_ID=5929928
NEXT_PUBLIC_EXOCLICK_MOBILE_BANNER_300X250_ZONE_ID=5929910
NEXT_PUBLIC_EXOCLICK_MOBILE_BANNER_300X100_ZONE_ID=5929930
NEXT_PUBLIC_EXOCLICK_FULLPAGE_INTERSTITIAL_ZONE_ID=5929932

# 広告差し込み間隔 (件)。0 以下なら差し込まない。
# /feed の縦スクロール内には現状差し込まない (UX 保護)。下記は一覧 / 検索結果用。
NEXT_PUBLIC_AD_LIST_INTERVAL=6
# (予約) フィード内ネイティブカード用。現在は未使用。
NEXT_PUBLIC_AD_FEED_INTERVAL=10

# ----------------------------------------------------------------------------
# apps/jobs (Python, GitHub Actions)
# ----------------------------------------------------------------------------
# DMM Webservice API (https://affiliate.dmm.com/api/)
# DMM_AFFILIATE_ID: API 呼び出し用 ID (末尾 -990〜-999 が必須)。
#   ItemList API のレスポンス `affiliateURL` はこの ID でトラッキング付きで発行され、
#   DMM 側のクリック計測に使われるため、そのまま DB に保存される。
# DMM_LINK_AFFILIATE_ID: (任意 / フォールバック専用) API が affiliateURL を返さない
#   場合に組み立てる直リンクの af_id。未設定なら DMM_AFFILIATE_ID にフォールバック。
#   通常運用では参照されない (女優詳細ページのフォールバックリンクで一部使用)。
DMM_API_ID=
DMM_AFFILIATE_ID=
DMM_LINK_AFFILIATE_ID=

# (任意) Playwright 実行時の追加オプション
# PLAYWRIGHT_HEADLESS=true
