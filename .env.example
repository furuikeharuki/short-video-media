# ============================================================================
# short-video-media: ルート .env.example
# ============================================================================
# このファイルはローカル開発用。本番値は Vercel / Railway / GitHub Actions の
# 各シークレットマネージャに設定すること。
# 1. このファイルを `.env` にコピー
# 2. 各値を本物の値に置き換え
# 3. `.env` は .gitignore に登録済み (絶対にコミットしない)

# ----------------------------------------------------------------------------
# 共通 (apps/api と apps/web で同一値)
# ----------------------------------------------------------------------------
# JWT HS256 署名鍵 / Auth.js セッション鍵 (32 文字以上)
# 生成: openssl rand -hex 32
AUTH_SECRET=

# provider sub のハッシュソルト (16 文字以上)
# 生成: openssl rand -hex 16
# ローテーション手順は docs/environments.md 参照
APP_USER_SALT=

# ----------------------------------------------------------------------------
# apps/api (FastAPI)
# ----------------------------------------------------------------------------
# 環境識別子 (production の場合に AUTH_SECRET / APP_USER_SALT の検証が厳格化)
APP_ENV=development

# DB 接続 (asyncpg ドライバへ自動正規化される)
DATABASE_URL=postgresql://shortvideo:shortvideo@127.0.0.1:5432/shortvideo

# events API レート制限 (IP ベースの sliding window)
EVENTS_RATE_LIMIT_PER_SECOND=10
EVENTS_RATE_LIMIT_PER_MINUTE=120

# CORS (カンマ区切り)
CORS_ALLOW_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# apps/web (Next.js)
# ----------------------------------------------------------------------------
# Twitter / Discord OAuth (developer portal から取得)
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# API 接続 URL (サーバー側 / クライアント側)
API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# GA4 (任意)
NEXT_PUBLIC_GA_ID=

# ----------------------------------------------------------------------------
# apps/jobs (Python, GitHub Actions)
# ----------------------------------------------------------------------------
# DMM Webservice API (https://affiliate.dmm.com/api/)
DMM_API_ID=
DMM_AFFILIATE_ID=

# (任意) Playwright 実行時の追加オプション
# PLAYWRIGHT_HEADLESS=true
