# ============================================================================
# infra/xserver/.env.example
# ----------------------------------------------------------------------------
# Xserver VPS 上で docker compose up する際の環境変数。
# 1. このファイルを `.env` にコピー (VPS 上で)
# 2. 値を本物に置き換え
# 3. `.env` は絶対にコミットしない (.gitignore 済み)
# ============================================================================

# ----------------------------------------------------------------------------
# DEPLOY 識別 (api / jobs-worker が共通参照)
# ----------------------------------------------------------------------------
DEPLOY_TARGET=xserver
APP_ENV=production

# ----------------------------------------------------------------------------
# Postgres (db サービス用)
# ----------------------------------------------------------------------------
POSTGRES_USER=shortvideo
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=shortvideo

# ----------------------------------------------------------------------------
# 認証 / セッション (api と Vercel(web) で同一値を共有)
# ----------------------------------------------------------------------------
# 生成: openssl rand -hex 32
AUTH_SECRET=
# 生成: openssl rand -hex 16
APP_USER_SALT=

# ----------------------------------------------------------------------------
# CORS (Vercel の web ドメインを必ず入れる)
# ----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://www.example.com,https://example.com

# ----------------------------------------------------------------------------
# events API レート制限 (任意, デフォルト値を上書きしたい場合のみ)
# ----------------------------------------------------------------------------
# EVENTS_RATE_LIMIT_PER_SECOND=10
# EVENTS_RATE_LIMIT_PER_MINUTE=120

# ----------------------------------------------------------------------------
# DMM サンプル動画 MP4 抽出 (apps/api 内 / in-process httpx)
# ----------------------------------------------------------------------------
# 旧 resolver コンテナは廃止された (Playwright 不要)。MP4 URL は apps/api が
# 直接 DMM の html5_player ページからピュア httpx で抽出する。
# タイムアウトを調整したい場合のみ環境変数で上書き (デフォルト 10000ms)。
# RESOLVER_TIMEOUT_MS=10000

# ----------------------------------------------------------------------------
# DMM Webservice API
# ----------------------------------------------------------------------------
DMM_API_ID=
DMM_AFFILIATE_ID=
DMM_LINK_AFFILIATE_ID=

# ----------------------------------------------------------------------------
# jobs (sync_catalog / sync_actress_profiles)
# ----------------------------------------------------------------------------
# jobs は常駐コンテナを廃止し、GitHub Actions ハイブリッド構成に移行済み。
#   - incremental sync_catalog (日 3 回): .github/workflows/jobs-sync-catalog.yml
#   - incremental sync_actress_profiles (日 1 回): .github/workflows/jobs-sync-actress.yml
#   - bootstrap (手動 dispatch):           .github/workflows/jobs-bootstrap.yml
# よって .env では SCHEDULER_BOOTSTRAP / SCHEDULER_RUN_ON_START / SCHEDULE_* は
# もう不要。古い .env に残っている場合は削除してクリーンに保つこと。
#
# Actions 側に追加で設定する必要がある Secrets:
#   XSERVER_DB_USER     = ${POSTGRES_USER}
#   XSERVER_DB_PASSWORD = ${POSTGRES_PASSWORD}
#   XSERVER_DB_NAME     = ${POSTGRES_DB}
#   DMM_API_ID / DMM_AFFILIATE_ID / DMM_LINK_AFFILIATE_ID
#   (既存) XSERVER_SSH_HOST / USER / PORT / KEY / KNOWN_HOSTS / REPO_DIR
#
# 1 ジョブで OOM しないよう BOOTSTRAP_CONCURRENCY=1 を推奨 (VPS RAM 1.9GB の場合)。
# RESOLVE_CONCURRENCY は jobs 内のサンプル URL 解決で参照されるなら残す。
RESOLVE_CONCURRENCY=4

# ----------------------------------------------------------------------------
# 定期実行 (cron) で「何を取得するか」を上書きする (任意)
# ----------------------------------------------------------------------------
# GitHub Actions の workflow_dispatch でも入力できるが、毎回 dispatch を叩かなくても
# VPS 側 .env でデフォルトを切り替えられるようにしてある。CLI フラグが渡された
# ときは CLI が常に優先される。空 / 未設定なら下記コメントの "ハードコード default"
# を使う。
#
# 設計方針: cron は常に「最新を取り続ける」運用のため、固定日付 (YYYY-MM-DD) を
# 受け付ける env はあえて用意していない。古い日付に固定されたまま放置されると
# 新着取りこぼしの事故になるため。期間スライス取得 (--mode full / --start-date /
# --end-date / --gte-date / --lte-date) はブートストラップ / 手動バックフィル時に
# CLI フラグで明示的に指定する。
#
# sync_catalog (jobs-sync-catalog.yml が cron で叩く / mode=incremental 固定)
#   - SYNC_CATALOG_HITS           : 1 フロアあたり取得件数 (int) (default: 100)
#   - SYNC_CATALOG_FLOORS         : カンマ区切り floor          (default: videoa,videoc)
#                                   有効値: videoa / videoc / goods
#   - SYNC_CATALOG_LOOKBACK_DAYS  : 起動時に (今日 - N 日) を gte_date として
#                                   API に渡す (int, 任意)。未設定なら DMM API の
#                                   フルレンジ + sort=date desc で最新から取る。
#                                   「直近 N 日も念のため再取得したい」用途に。
#                                   毎回起動時刻基準で計算されるため日付が固定化されない。
#   - SYNC_CATALOG_DRY_RUN        : 1/true で DB に書かない      (default: 0)
#
# sync_actress_profiles (jobs-sync-actress.yml が cron で叩く)
#   - SYNC_ACTRESS_LIMIT         : 処理件数上限 (int, 未設定で全件)
#   - SYNC_ACTRESS_ONLY_MISSING  : 1/true で ruby/birthday/image_url_large 欠落だけ更新
#   - SYNC_ACTRESS_DRY_RUN       : 1/true で DB に書かない
#
# 例: cron で goods フロアも含めて 200 件ずつ取りたい場合:
# SYNC_CATALOG_FLOORS=videoa,videoc,goods
# SYNC_CATALOG_HITS=200
#
# 例: 直近 7 日に発売されたものは毎回上書き取得しなおしたい場合:
# SYNC_CATALOG_LOOKBACK_DAYS=7


# ----------------------------------------------------------------------------
# Caddy (reverse proxy)
# ----------------------------------------------------------------------------
# docker compose --profile proxy up -d で起動する場合のみ必要。
# 既存 resolver の Caddy / nginx を使っているなら未設定で OK。
API_DOMAIN=api.example.com
