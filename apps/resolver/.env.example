# apps/resolver 環境変数のサンプル。本番では値を書き換えて .env に置く。

# Bearer 認証キー (apps/api と共有する)
RESOLVER_API_KEY=devkey

# DMM アフィリエイト ID (例: xxxx-001)
DMM_AFFILIATE_ID=

# 同時実行制御 (Xserver VPS 2GB なら 2 推奨)
RESOLVER_CONCURRENCY=2

# Playwright タイムアウト (ms)
RESOLVER_NAV_TIMEOUT_MS=15000
RESOLVER_WAIT_VIDEO_TIMEOUT_MS=8000

# ログレベル
RESOLVER_LOG_LEVEL=INFO
