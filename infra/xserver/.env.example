# ============================================================================
# infra/xserver/.env.example
# ----------------------------------------------------------------------------
# Xserver VPS 上で docker compose up する際の環境変数。
# 1. このファイルを `.env` にコピー (VPS 上で)
# 2. 値を本物に置き換え
# 3. `.env` は絶対にコミットしない (.gitignore 済み)
# ============================================================================

# ----------------------------------------------------------------------------
# DEPLOY 識別 (api / jobs-worker が共通参照)
# ----------------------------------------------------------------------------
DEPLOY_TARGET=xserver
APP_ENV=production

# ----------------------------------------------------------------------------
# Postgres (db サービス用)
# ----------------------------------------------------------------------------
POSTGRES_USER=shortvideo
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=shortvideo

# ----------------------------------------------------------------------------
# 認証 / セッション (api と Vercel(web) で同一値を共有)
# ----------------------------------------------------------------------------
# 生成: openssl rand -hex 32
AUTH_SECRET=
# 生成: openssl rand -hex 16
APP_USER_SALT=

# ----------------------------------------------------------------------------
# CORS (Vercel の web ドメインを必ず入れる)
# ----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://www.example.com,https://example.com

# ----------------------------------------------------------------------------
# events API レート制限 (任意, デフォルト値を上書きしたい場合のみ)
# ----------------------------------------------------------------------------
# EVENTS_RATE_LIMIT_PER_SECOND=10
# EVENTS_RATE_LIMIT_PER_MINUTE=120

# ----------------------------------------------------------------------------
# DMM サンプル動画 MP4 抽出 (apps/api 内 / in-process httpx)
# ----------------------------------------------------------------------------
# 旧 resolver コンテナは廃止された (Playwright 不要)。MP4 URL は apps/api が
# 直接 DMM の html5_player ページからピュア httpx で抽出する。
# タイムアウトを調整したい場合のみ環境変数で上書き (デフォルト 10000ms)。
# RESOLVER_TIMEOUT_MS=10000

# ----------------------------------------------------------------------------
# DMM Webservice API
# ----------------------------------------------------------------------------
DMM_API_ID=
DMM_AFFILIATE_ID=
DMM_LINK_AFFILIATE_ID=

# ----------------------------------------------------------------------------
# jobs-worker 起動オプション
# ----------------------------------------------------------------------------
# 初回データ取り込み時のみ true。完了後は false に戻して再デプロイ。
SCHEDULER_BOOTSTRAP=false
# scheduler 起動直後に sync_catalog を 1 回走らせるか (デバッグ用)
SCHEDULER_RUN_ON_START=false
# resolve_sample_urls (バックフィル job) の並列数。
# DMM へのアクセス間隔が縮みすぎないよう、控えめに設定する。
RESOLVE_CONCURRENCY=4

# ----------------------------------------------------------------------------
# 定期実行 (APScheduler) のチューニング — 任意。未設定なら従来の挙動。
# ----------------------------------------------------------------------------
# ジョブ単位の有効/無効。"false" で APScheduler に登録しない。
# SCHEDULE_ENABLE_SYNC_CATALOG=true
# SCHEDULE_ENABLE_RESOLVE_SAMPLE_URLS=true
# SCHEDULE_ENABLE_ACTRESS_PROFILES=true
# 月次フルリフレッシュ (sample_movie_url を全件再解決) はデフォルト無効。
# DMM の CDN URL は数週間〜数カ月で期限切れになるため、true にすると
# 月 1 回 (毎月 1 日 03:00 JST) すべての解決済み movies を再解決する。
# SCHEDULE_ENABLE_RESOLVE_SAMPLE_URLS_FULL_REFRESH=false
#
# sync_catalog の取得対象
#   mode: "incremental" (デフォルト) / "full"
#   floors: カンマ区切り。未設定なら sync_catalog のデフォルト (動画 + goods)
#   hits_per_floor: 1 floor あたり取得件数 (デフォルト 100)
# SCHEDULE_SYNC_CATALOG_MODE=incremental
# SCHEDULE_SYNC_CATALOG_FLOORS=videoa,videoc
# SCHEDULE_SYNC_CATALOG_HITS_PER_FLOOR=100
#
# resolve_sample_urls の対象上限 (未設定なら NULL のもの全件)
# SCHEDULE_RESOLVE_LIMIT=
# 月次フルリフレッシュの件数上限 (未設定なら全件再解決)
# SCHEDULE_RESOLVE_FULL_REFRESH_LIMIT=
#
# sync_actress_profiles の挙動
# SCHEDULE_ACTRESS_ONLY_MISSING=true
# SCHEDULE_ACTRESS_LIMIT=
#
# cron 時刻 (JST 評価)。デフォルトは sync 2h ごと / resolve 11:00 / actress 13:00
# SCHEDULE_SYNC_CATALOG_CRON_HOUR=8,10,12,14,16,18,20
# SCHEDULE_SYNC_CATALOG_CRON_MINUTE=0
# SCHEDULE_RESOLVE_CRON_HOUR=11
# SCHEDULE_RESOLVE_CRON_MINUTE=0
# 月次フルリフレッシュ (デフォルト 毎月 1 日 03:00 JST)
# SCHEDULE_RESOLVE_FULL_REFRESH_CRON_DAY=1
# SCHEDULE_RESOLVE_FULL_REFRESH_CRON_HOUR=3
# SCHEDULE_RESOLVE_FULL_REFRESH_CRON_MINUTE=0
# SCHEDULE_ACTRESS_CRON_HOUR=13
# SCHEDULE_ACTRESS_CRON_MINUTE=0

# ----------------------------------------------------------------------------
# Caddy (reverse proxy)
# ----------------------------------------------------------------------------
# docker compose --profile proxy up -d で起動する場合のみ必要。
# 既存 resolver の Caddy / nginx を使っているなら未設定で OK。
API_DOMAIN=api.example.com
