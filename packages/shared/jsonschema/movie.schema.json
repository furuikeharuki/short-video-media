{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://short-video-media/schemas/movie.schema.json",
  "title": "MovieDetail",
  "type": "object",
  "required": ["id", "title", "slug", "affiliate_url"],
  "properties": {
    "id": { "type": "string" },
    "content_id": { "type": ["string", "null"] },
    "title": { "type": "string" },
    "slug": { "type": "string" },
    "image_url_list": { "type": ["string", "null"], "format": "uri" },
    "image_url_large": { "type": ["string", "null"], "format": "uri" },
    "sample_movie_url": { "type": ["string", "null"], "format": "uri" },
    "affiliate_url": { "type": "string", "format": "uri" },
    "price_list": {
      "type": ["object", "null"],
      "properties": {
        "list_price": { "type": ["number", "null"] },
        "sale_price": { "type": ["number", "null"] },
        "rental_price": { "type": ["number", "null"] },
        "delivery_price": { "type": ["number", "null"] }
      }
    },
    "price_min": { "type": ["number", "null"] },
    "review_count": { "type": "integer", "minimum": 0 },
    "review_average": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
    "release_date": { "type": ["string", "null"], "format": "date" },
    "duration_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "maker": { "type": ["string", "null"] },
    "label": { "type": ["string", "null"] },
    "series": { "type": ["string", "null"] },
    "director": { "type": ["string", "null"] },
    "actresses": {
      "type": "array",
      "items": { "$ref": "#/$defs/ActressBrief" }
    },
    "genres": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description": { "type": ["string", "null"] }
  },
  "$defs": {
    "ActressBrief": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "slug": { "type": ["string", "null"] },
        "thumbnail_url": { "type": ["string", "null"], "format": "uri" }
      }
    }
  }
}
