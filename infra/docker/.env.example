# ============================================================================
# infra/docker/.env.example
# ============================================================================
# docker compose 用の環境変数テンプレート。
# このファイルを `infra/docker/.env` にコピーして使う。

# --- DB (postgres コンテナ) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=short_video_media

# --- apps/api コンテナ ---
APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@db:5432/short_video_media
AUTH_SECRET=change_me_openssl_rand_hex_32
APP_USER_SALT=change_me_openssl_rand_hex_16
EVENTS_RATE_LIMIT_PER_SECOND=10
EVENTS_RATE_LIMIT_PER_MINUTE=120
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- apps/jobs コンテナ (任意 / --profile jobs 利用時) ---
# DMM_AFFILIATE_ID: API 呼び出し用 ID (末尾 -990〜-999 が必須)。
#   API レスポンスの `affiliateURL` (DMM 公式トラッキング URL) はこの ID で発行され、
#   そのまま DB に保存される。
# DMM_LINK_AFFILIATE_ID: (任意 / フォールバック専用) API が affiliateURL を返さない
#   ケースの直リンク af_id。未設定なら DMM_AFFILIATE_ID にフォールバック。
DMM_API_ID=
DMM_AFFILIATE_ID=
DMM_LINK_AFFILIATE_ID=
