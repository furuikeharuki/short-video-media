# ===== 環境変数（絶対にコミットしない） =====
.env
.env.local
# 本番用も念のため除外
.env.production
# .env.development.local 等もカバー
.env.*.local

# ただし .env.example は上のパターンに引っかからないのでコミットされる

# ===== Python =====
*.pyc
__pycache__/
# 仮想環境
.venv/
*.egg-info/

# ===== Node.js =====
# .gitignore はインラインの '#' をサポートしないので、コメントは別行に置くこと。
node_modules/
apps/web/.next/
apps/web/out/
# TypeScript インクリメンタルビルドキャッシュ
apps/web/tsconfig.tsbuildinfo
**/*.tsbuildinfo

# ===== OS / エディタ =====
.DS_Store
